        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "clock": {
        "timezone": "America/Los_Angeles",
        "format": "{:%H:%M %p пЊ·}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d пЊ·}"
    },
    "cpu": {
        "format": "{usage}% п„±",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пЏ "
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["п‰­", "пЌЄ", "пЌ«", "пЌ¬", "пЌ­", "пЌ®", "пЌЇ"],
        "on-scroll-up": "xbacklight -inc 5",
        "on-scroll-down": "xbacklight -dec 5"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п–ѓ",
        "format-plugged": "{capacity}% п–ѓ",
        "format-alt": "{time} {icon} ",
        "format-icons": ["п•№", "п•є", "п•»", "п•ј", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} п‹Ё",
        "format-ethernet": "{ipaddr}/{cidr} пЉІ",
        "tooltip-format": "{ifname} {gwaddr} п‹Ё",
        "format-linked": "{ifname} (No IP) п‹Ё",
        "format-disconnected": "Disconnected п‹¦",
        "format-alt": "{ifname} ({signalStrength}%) п‹Ё"
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{volume}% {icon} п‘„ {format_source}",
        "format-bluetooth": "{volume}% {icon}пЉ‚ {format_source}",
        "format-bluetooth-muted": "п±ќ {icon}пЉ‚ {format_source}",
        "format-muted": "{format_source}",
        "format-source": "{volume}% пЉ«",
        "format-source-muted": "пЉЁ",
        "format-icons": {
            "headphone": "пЉќ",
            "hands-free": "п„•",
            "headset": "п„•",
            "phone": "пЉѕ",
            "portable": "пЉѕ",
            "car": "п„Ґ",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
