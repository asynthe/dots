{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    "width": 1920, // Waybar width
    "spacing": 10, // Gaps between modules
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "fixed-center": true,
    "gtk-layer-shell": true,


    // Choose the order of the modules
    "modules-left": ["wlr/workspaces", "wlr/taskbar", "custom/spotify-title", "custom/spotify-prev", "custom/spotify-toggle", "custom/spotify-next"],
    "modules-center": [],
    "modules-right": ["idle_inhibitor", "pulseaudio", "network", "backlight", "tray", "battery", "clock"],

    // Modules configuration
    "wlr/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "urgent": "п‰±",
            "active": "п‰­",
            "default": "п‰¬"
        },
        "sort-by-number": true
    },
    "wlr/taskbar": {
        "format": "{icon} {name}",
        "icon-size": 14,
        "icon-theme": "sakura",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "all-outputs": false
    },
    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "п†ђ",
            "unlocked": "п†Џ"
        }
    },
    "idle_inhibitor": {
